# JISP environment variables — example file.
# Copy to `.env` for local use. Do NOT commit real secrets.

# --- API ---
JISP_API_HOST=0.0.0.0
JISP_API_PORT=8000

# --- Database (PostgreSQL + PostGIS + TimescaleDB) ---
JISP_DB_HOST=db
JISP_DB_PORT=5432
JISP_DB_NAME=jisp
JISP_DB_USER=jisp
JISP_DB_PASSWORD=change-me

# --- Ollama (reasoning) ---
JISP_OLLAMA_HOST=http://ollama:11434
JISP_OLLAMA_MODEL=kimi

# --- Regional config ---
JISP_REGION=us
